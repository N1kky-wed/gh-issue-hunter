{
  "manifest_version": 3,
  "name": "GitHub PR Filter — Highlight & Hide",
  "version": "2.0",
  "description": "Highlights, dims, or hides GitHub issues based on their PR status. Fully configurable from the popup.",
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/issues*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "GitHub PR Filter"
  }
}
